<Window x:Class="TowerDefenseWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TowerDefenseWPF"
        mc:Ignorable="d"
        Title="Defensa de Torres WPF" Height="640" Width="1300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#FF14141C"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF55556F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF55557A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF2A2A35"/>
                                <Setter Property="Foreground" Value="#FF666677"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1000"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#FF2A2A3A" BorderThickness="0,0,2,0">
            <Grid>
                <Canvas x:Name="GameCanvas" Width="1000" Height="600"
                        MouseDown="AlHacerClicEnLienzo_Presionado"
                        MouseMove="AlMoverEnLienzo">
                    <Canvas.Background>
                        <ImageBrush ImageSource="/Img/Fondo.jpeg"
                            Stretch="UniformToFill"/>
                    </Canvas.Background>
                </Canvas>
                <Border x:Name="EndOverlay" Background="#CC000000"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="EndTitle" Text="" Foreground="White"
                                   FontSize="48" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="EndSubtitle" Text="" Foreground="#FFCCCCDD"
                                   FontSize="18" HorizontalAlignment="Center" Margin="0,8,0,20"/>
                        <Button Content="Reiniciar" Padding="20,10" FontSize="16"
                                HorizontalAlignment="Center" Click="BotónReiniciar_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Background="#FF35272F">
            <StackPanel>
                <TextBlock Text="DEFENSA DE TORRES" Foreground="#FFFFCC44"
                           FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,12,0,8"/>

                <Border Background="#FF2E2E3E" Margin="10,5" Padding="10" CornerRadius="6">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Oleada:" Foreground="#FFCCCCDD"/>
                            <TextBlock x:Name="WaveLabel" Grid.Column="1" Text="0 / 10"
                                       Foreground="#FFFFCC44" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Vidas:" Foreground="#FFCCCCDD"/>
                            <TextBlock x:Name="LivesLabel" Grid.Column="1" Text="20"
                                       Foreground="#FFFF6666" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Oro:" Foreground="#FFCCCCDD"/>
                            <TextBlock x:Name="GoldLabel" Grid.Column="1" Text="200"
                                       Foreground="#FFFFD700" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cola spawn:" Foreground="#FFCCCCDD"/>
                            <TextBlock x:Name="QueueLabel" Grid.Column="1" Text="0"
                                       Foreground="#FFCCCCDD"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button x:Name="StartWaveButton" Content="▶ Iniciar oleada"
                        Margin="10,5" Click="BotónIniciarOleada_Click"/>
                <Button x:Name="UndoButton" Content="↶ Deshacer última acción"
                        Margin="10,5" Click="BotónDeshacer_Click" IsEnabled="False"/>

                <TextBlock Text="Construir torre" Foreground="#FFCCCCDD" FontSize="14"
                           FontWeight="Bold" Margin="14,10,0,4"/>

                <StackPanel x:Name="TowerButtonsPanel" Margin="10,0"/>

                <TextBlock x:Name="StatusLabel" Text="" Foreground="#FFFFCC44"
                           TextWrapping="Wrap" Margin="14,8,14,4" FontSize="12"/>

                <Border x:Name="UpgradePanel" Background="#FF2E2E3E"
                        Margin="10,5" Padding="10" CornerRadius="6"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="SelectedTowerLabel" Text=""
                                   Foreground="#FFFFCC44" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="TowerStatsLabel" Text=""
                                   Foreground="White" FontSize="11" Margin="0,4,0,6"/>

                        <TextBlock Text="Árbol de mejoras:" Foreground="#FFCCCCDD"
                                   FontSize="12" Margin="0,4,0,2"/>
                        <Canvas x:Name="TreeCanvas" Width="240" Height="130"
                                Background="#FF1A1A22"/>

                        <TextBlock Text="Mejoras disponibles:" Foreground="#FFCCCCDD"
                                   FontSize="12" Margin="0,8,0,4"/>
                        <StackPanel x:Name="UpgradeOptionsPanel"/>

                        <Button x:Name="SellTowerButton" Content="Vender torre"
                                Margin="0,8,0,0" Click="BotónVenderTorre_Click"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Click en una torre para mejorarla."
                           Foreground="#FF777788" FontSize="10"
                           TextWrapping="Wrap" Margin="14,8,14,12"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
